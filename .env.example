# =============================================================================
# Docker Compose — optional root-level overrides (copy to .env next to docker-compose.yml)
# backend/.env is still loaded via env_file; these vars tune the stack only.
# =============================================================================

POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin123
POSTGRES_DB=editor_db

# Host port published for the backend API (container listens on 8001)
BACKEND_HOST_PORT=8001

# Optional: force in-stack Qdrant instead of cloud URL from backend/.env
# QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=
