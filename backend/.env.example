# =============================================================================
# Cybrain QS backend — environment template
# Copy to backend/.env and fill in secrets. Do not commit backend/.env.
#
# Profiles:
#   Local uvicorn (Windows/host): use 127.0.0.1:8001 URLs below
#   Docker Compose: docker-compose.yml overrides API/webhook/DB paths automatically
# =============================================================================

# --- API base (host dev: 8001; Docker Compose sets http://backend:8001) ---
API_BASE_URL=http://127.0.0.1:8001

COLLECTION_NAME=hybrid_rag_docs
COLLECTION_SOPS=docs_sops
COLLECTION_DEVIATIONS=docs_deviations
COLLECTION_CAPAS=docs_capas
COLLECTION_DECISIONS=docs_decisions
COLLECTION_AUDITS=docs_audits

ENDPOINT_SOPS=/api/public/sops/full?status=all&page=1&page_size=50
ENDPOINT_DEVIATIONS=/api/deviations
ENDPOINT_CAPAS=/api/capas
ENDPOINT_DECISIONS=/api/decisions
ENDPOINT_AUDITS=/api/audits

# Webhook fetch targets (must reach this backend; host dev uses 127.0.0.1:8001)
WEBHOOK_ENDPOINT_SOPS=http://127.0.0.1:8001/api/public/sops/full?status=all&page=1&page_size=50
WEBHOOK_ENDPOINT_DEVIATIONS=http://127.0.0.1:8001/api/deviations
WEBHOOK_ENDPOINT_CAPAS=http://127.0.0.1:8001/api/capas
WEBHOOK_ENDPOINT_DECISIONS=http://127.0.0.1:8001/api/decisions
WEBHOOK_ENDPOINT_AUDITS=http://127.0.0.1:8001/api/audits
WEBHOOK_SECRET=change-me

CHATBOT_USE_LOCAL_DB=false

# Qdrant: cloud URL and/or local stack (Compose default: http://qdrant:6333 if unset)
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=

# PostgreSQL (Compose service name: db)
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL_LOCAL=postgresql://postgres:admin123@127.0.0.1:5433/editor_db
DATABASE_URL_DOCKER=postgresql://postgres:admin123@db:5432/editor_db

JWT_SECRET_KEY=change-me
JWT_REFRESH_SECRET_KEY=change-me

LLM_PROVIDER=local_openai
LOCAL_LLM_BASE_URL=http://192.168.100.15:1234/v1
LOCAL_LLM_MODEL=google/gemma-4-e4b
# true = LLM classifies intent/target (rules only enrich + guardrails). false = legacy rule-first routing.
ASSISTANT_LLM_ORCHESTRATOR=true
ASSISTANT_INTENT_MAX_TOKENS=512
LOCAL_LLM_API_KEY=
LOCAL_LLM_TIMEOUT_SECONDS=120
LOCAL_LLM_HEALTH_MODELS_TIMEOUT=90
LOCAL_LLM_HEALTH_CHAT_TIMEOUT=120

RAG_MAX_OUTPUT_TOKENS=32768
ACTION_MAX_OUTPUT_TOKENS=32768
ACTION_LLM_MAX_TOKENS=8192
ACTION_MODEL_CONTEXT_TOKENS=32768
ACTION_PROMPT_SOFT_LIMIT=24000
RAG_ACTIVE_IDS_CACHE_SECONDS=10
CHAT_QUERY_TIMEOUT_SECONDS=120
EMBEDDING_WORKER_POLL_SECONDS=0.6

# Host-only paths (Docker Compose overrides TESSERACT/POPPLER/HF paths in compose)
HF_HOME=../.hf-cache
HUGGINGFACE_HUB_CACHE=../.hf-cache/hub
EMBEDDING_HF_CACHE_DIR=../.hf-cache
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
POPPLER_PATH=
